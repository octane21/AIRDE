PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_NAME=airde_db
DB_USER=postgres
DB_PASSWORD=your_password_here
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# Comma-separated list of allowed frontend origins (production). Leave unset for local dev.
CORS_ORIGIN=https://your-frontend.vercel.app

# Production (managed Postgres e.g. Neon/Render/Supabase): set DATABASE_URL instead of the
# DB_* vars above, and set DB_SSL=true. Local Postgres install does not need either.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL=true
