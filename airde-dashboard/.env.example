# ============================================================
# AIRDE Dashboard - Environment Variables (frontend)
# ============================================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
# ============================================================

# Groq API key for the AI Assistant chat. Get a free key at https://console.groq.com/keys
VITE_GROQ_API_KEY=

# Model Groq yang tersedia (pilih salah satu):
#   llama-3.3-70b-versatile    → Paling cerdas, recommended
#   llama-3.1-8b-instant       → Paling cepat
#   mixtral-8x7b-32768         → Context panjang
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# Backend API origin. Leave empty for local dev (uses the Vite proxy to localhost:3001) or when
# frontend+backend are served from the same domain. Set to the deployed backend's full URL when
# the frontend is hosted separately (e.g. on Vercel/Netlify while the backend runs on Render).
# VITE_API_URL=https://airde-backend.onrender.com
