# Dependencies (matches at any depth: airde-dashboard/node_modules, backend/node_modules)
node_modules

# Frontend build output
dist
dist-ssr

# Environment variables / secrets (both frontend .env.local and backend/.env)
.env
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Uploaded files (keep the folder, ignore its contents)
backend/uploads/*
!backend/uploads/.gitkeep

# Source workbook / Office lock files — reference material kept locally only
*.xlsx
~$*
.word
*.docx

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
